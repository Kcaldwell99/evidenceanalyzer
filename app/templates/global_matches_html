<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Global Match Dashboard — Evidentix&#8482;</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      background: #0f1117;
      color: #e2e8f0;
      min-height: 100vh;
    }
    .container { max-width: 1100px; margin: 0 auto; padding: 2rem 1rem; }
    .back { display: inline-block; color: #7c8cf8; text-decoration: none; font-size: 0.85rem; margin-bottom: 1.5rem; }
    .back:hover { text-decoration: underline; }
    .header { margin-bottom: 2rem; }
    .header h1 { font-size: 1.6rem; font-weight: 700; color: #7c8cf8; }
    .header p { color: #94a3b8; margin-top: 0.4rem; font-size: 0.9rem; }
    .stats {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1rem;
      margin-bottom: 2rem;
    }
    .stat {
      background: #1a1d27;
      border: 1px solid #2d3148;
      border-radius: 12px;
      padding: 1.25rem;
      text-align: center;
    }
    .stat .value { font-size: 1.8rem; font-weight: 700; color: #7c8cf8; }
    .stat .label { font-size: 0.75rem; color: #64748b; margin-top: 0.25rem; }
    .card {
      background: #1a1d27;
      border: 1px solid #2d3148;
      border-radius: 12px;
      padding: 1.5rem;
      margin-bottom: 1.5rem;
    }
    .card h2 { font-size: 1rem; font-weight: 600; color: #e2e8f0; margin-bottom: 1rem; padding-bottom: 0.5rem; border-bottom: 1px solid #2d3148; }
    table { width: 100%; border-collapse: collapse; font-size: 0.82rem; }
    th { text-align: left; padding: 0.5rem 0.75rem; color: #64748b; font-size: 0.75rem; text-transform: uppercase; border-bottom: 1px solid #2d3148; }
    td { padding: 0.6rem 0.75rem; border-bottom: 1px solid #0f1117; vertical-align: top; }
    tr:last-child td { border-bottom: none; }
    .badge {
      display: inline-block;
      padding: 0.15rem 0.5rem;
      border-radius: 4px;
      font-size: 0.72rem;
      font-weight: 600;
    }
    .badge.high { background: #3b1f1f; color: #f87171; }
    .badge.possible { background: #2d2a1a; color: #fcd34d; }
    .score-high { color: #f87171; font-weight: 700; }
    .score-possible { color: #fcd34d; font-weight: 600; }
    .empty { color: #475569; font-style: italic; text-align: center; padding: 2rem; }
    a.case-link { color: #7c8cf8; text-decoration: none; }
    a.case-link:hover { text-decoration: underline; }
  </style>
</head>
<body>
  <div class="container">
    <a href="/" class="back">← Back to Dashboard</a>

    <div class="header">
      <h1>Global Match Dashboard</h1>
      <p>Cross-case similarity matches across all indexed evidence.</p>
    </div>

    <div class="stats">
      <div class="stat">
        <div class="value">{{ total_indexed }}</div>
        <div class="label">Files Indexed</div>
      </div>
      <div class="stat">
        <div class="value">{{ matches|length }}</div>
        <div class="label">Matches Found</div>
      </div>
      <div class="stat">
        <div class="value">{{ matches|selectattr('match_level', 'equalto', 'High Match')|list|length }}</div>
        <div class="label">High Confidence Matches</div>
      </div>
    </div>

    <div class="card">
      <h2>Similarity Matches</h2>
      {% if matches %}
      <table>
        <thead>
          <tr>
            <th>File A</th>
            <th>Case A</th>
            <th>File B</th>
            <th>Case B</th>
            <th>Similarity</th>
            <th>Match Level</th>
          </tr>
        </thead>
        <tbody>
          {% for m in matches %}
          <tr>
            <td>
              {{ m.file_a }}<br>
              <small style="color:#64748b;">{{ m.evidence_a }}</small>
            </td>
            <td><a href="/cases/{{ m.case_a }}" class="case-link">{{ m.case_a }}</a></td>
            <td>
              {{ m.file_b }}<br>
              <small style="color:#64748b;">{{ m.evidence_b }}</small>
            </td>
            <td><a href="/cases/{{ m.case_b }}" class="case-link">{{ m.case_b }}</a></td>
            <td class="{% if m.similarity >= 85 %}score-high{% else %}score-possible{% endif %}">
              {{ m.similarity }}%
            </td>
            <td>
              <span class="badge {% if m.match_level == 'High Match' %}high{% else %}possible{% endif %}">
                {{ m.match_level }}
              </span>
            </td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
      {% else %}
      <p class="empty">No cross-case matches found. Upload and analyze evidence across multiple cases to see matches here.</p>
      {% endif %}
    </div>
  </div>
</body>
</html>